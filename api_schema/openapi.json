{
  "openapi": "3.0.0",
  "paths": {
    "/api/jobs": {
      "post": {
        "operationId": "JobsController_create",
        "summary": "Create a URL-checking job (processes async).",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateJobDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateJobResponseDto"
                }
              }
            }
          }
        },
        "tags": [
          "jobs"
        ]
      },
      "get": {
        "operationId": "JobsController_list",
        "summary": "List jobs (newest first).",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/JobSummaryDto"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "jobs"
        ]
      }
    },
    "/api/jobs/{id}": {
      "get": {
        "operationId": "JobsController_get",
        "summary": "Get full job detail.",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobDetailDto"
                }
              }
            }
          },
          "404": {
            "description": "Job not found."
          }
        },
        "tags": [
          "jobs"
        ]
      },
      "delete": {
        "operationId": "JobsController_cancel",
        "summary": "Cancel a job (idempotent). Returns full detail.",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobDetailDto"
                }
              }
            }
          },
          "404": {
            "description": "Job not found."
          }
        },
        "tags": [
          "jobs"
        ]
      }
    },
    "/api/health": {
      "get": {
        "operationId": "HealthController_check",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "example": {
                    "status": "ok"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "health"
        ]
      }
    }
  },
  "info": {
    "title": "URL Checker API",
    "description": "Async URL-checking service.",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "CreateJobDto": {
        "type": "object",
        "properties": {
          "urls": {
            "description": "List of http/https URLs to check (deduplicated server-side).",
            "example": [
              "https://example.com",
              "https://nestjs.com"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "urls"
        ]
      },
      "CreateJobResponseDto": {
        "type": "object",
        "properties": {
          "jobId": {
            "type": "string",
            "description": "Unique identifier of the newly created job.",
            "example": "b3f1c2e4-5a6b-7c8d-9e0f-1a2b3c4d5e6f"
          }
        },
        "required": [
          "jobId"
        ]
      },
      "JobStatus": {
        "type": "string",
        "enum": [
          "pending",
          "in_progress",
          "completed",
          "cancelled",
          "failed"
        ]
      },
      "JobSummaryStatsDto": {
        "type": "object",
        "properties": {
          "success": {
            "type": "number",
            "example": 3
          },
          "error": {
            "type": "number",
            "example": 1
          }
        },
        "required": [
          "success",
          "error"
        ]
      },
      "JobSummaryDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "b3f1c2e4-5a6b-7c8d-9e0f-1a2b3c4d5e6f"
          },
          "createdAt": {
            "type": "string",
            "example": "2026-06-23T10:00:00.000Z"
          },
          "status": {
            "$ref": "#/components/schemas/JobStatus"
          },
          "urlCount": {
            "type": "number",
            "example": 4
          },
          "stats": {
            "$ref": "#/components/schemas/JobSummaryStatsDto"
          }
        },
        "required": [
          "id",
          "createdAt",
          "status",
          "urlCount",
          "stats"
        ]
      },
      "JobDetailStatsDto": {
        "type": "object",
        "properties": {
          "success": {
            "type": "number",
            "example": 3
          },
          "error": {
            "type": "number",
            "example": 1
          },
          "pending": {
            "type": "number",
            "example": 0
          },
          "inProgress": {
            "type": "number",
            "example": 0
          },
          "cancelled": {
            "type": "number",
            "example": 0
          }
        },
        "required": [
          "success",
          "error",
          "pending",
          "inProgress",
          "cancelled"
        ]
      },
      "UrlStatus": {
        "type": "string",
        "enum": [
          "pending",
          "in_progress",
          "success",
          "error",
          "cancelled"
        ]
      },
      "UrlResultDto": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "example": "https://example.com"
          },
          "status": {
            "$ref": "#/components/schemas/UrlStatus"
          },
          "httpStatus": {
            "type": "number",
            "nullable": true,
            "example": 200,
            "description": "HTTP status code returned by the HEAD request, if any."
          },
          "error": {
            "type": "string",
            "nullable": true,
            "example": null,
            "description": "Error detail (e.g. \"timeout\", \"ENOTFOUND\", \"HTTP 404\")."
          },
          "startedAt": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "finishedAt": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "durationMs": {
            "type": "number",
            "nullable": true,
            "example": null
          }
        },
        "required": [
          "url",
          "status",
          "httpStatus",
          "error",
          "startedAt",
          "finishedAt",
          "durationMs"
        ]
      },
      "JobDetailDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "b3f1c2e4-5a6b-7c8d-9e0f-1a2b3c4d5e6f"
          },
          "createdAt": {
            "type": "string",
            "example": "2026-06-23T10:00:00.000Z"
          },
          "status": {
            "$ref": "#/components/schemas/JobStatus"
          },
          "startedAt": {
            "type": "string",
            "nullable": true
          },
          "finishedAt": {
            "type": "string",
            "nullable": true
          },
          "processed": {
            "type": "number",
            "example": 4,
            "description": "total - pending - inProgress"
          },
          "stats": {
            "$ref": "#/components/schemas/JobDetailStatsDto"
          },
          "urls": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UrlResultDto"
            }
          }
        },
        "required": [
          "id",
          "createdAt",
          "status",
          "startedAt",
          "finishedAt",
          "processed",
          "stats",
          "urls"
        ]
      }
    }
  }
}
