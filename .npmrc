# The React Query codegen (@7nohe/openapi-react-query-codegen) declares a stale
# peer range (ts-morph 23.x) but works with ts-morph 27 — required so its bundled
# TypeScript matches the project's typescript 5.9 (SyntaxKind parity). Use the
# legacy resolver so `npm install` / `npm ci` don't fail on that peer mismatch.
legacy-peer-deps=true
